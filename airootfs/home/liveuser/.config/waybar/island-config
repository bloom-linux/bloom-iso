{
    "layer": "overlay",
    "position": "top",
    "margin-top": 8,
    "exclusive": false,
    "passthrough": false,
    "fixed-center": true,
    "height": 38,

    "modules-left":   [],
    "modules-center": ["hyprland/window", "mpris", "custom/notif"],
    "modules-right":  [],

    "hyprland/window": {
        "format": "{class}",
        "max-length": 32,
        "rewrite": {
            "kitty":             " kitty",
            "foot":              " foot",
            "alacritty":         " term",
            "Alacritty":         " term",
            "firefox":           "󰈹 firefox",
            "Firefox":           "󰈹 firefox",
            "chromium":          " chromium",
            "brave-browser":     " brave",
            "thunar":            "󰉋 files",
            "Thunar":            "󰉋 files",
            "nemo":              "󰉋 files",
            "nautilus":          "󰉋 files",
            "code":              "󰨞 code",
            "code-oss":          "󰨞 code",
            "Code":              "󰨞 code",
            "nvim":              " nvim",
            "neovim":            " nvim",
            "mpv":               " mpv",
            "vlc":               "󰕼 vlc",
            "discord":           "󰙯 discord",
            "telegram-desktop":  " telegram",
            "steam":             "󰓓 steam",
            "gimp-2.10":         " gimp",
            "gimp":              " gimp",
            "inkscape":          "󰺩 inkscape",
            "obs":               " obs",
            "rofi":              "❀ bloom",
            "":                  "❀ bloom"
        },
        "separate-outputs": false,
        "tooltip": false
    },

    "mpris": {
        "format": "{player_icon}  {title}",
        "format-paused": "{status_icon}  {title}",
        "player-icons": {
            "default":   "▶",
            "spotify":   "󰓇",
            "firefox":   "󰈹",
            "vlc":       "󰕼",
            "mpv":       "",
            "rhythmbox": "󰓃",
            "chromium":  "",
            "brave":     ""
        },
        "status-icons": {
            "paused":  "⏸",
            "stopped": "⏹"
        },
        "max-length": 44,
        "on-click":       "playerctl play-pause",
        "on-click-right": "playerctl stop",
        "on-scroll-up":   "playerctl next",
        "on-scroll-down": "playerctl previous",
        "tooltip-format": "{title}\n{artist}\n{album}\n\n↑ scroll: next   ↓ scroll: prev   click: play/pause"
    },

    "custom/notif": {
        "exec": "/etc/xdg/waybar/scripts/island-notif.sh",
        "return-type": "json",
        "interval": 4,
        "format": "{}",
        "on-click": "swaync-client -t -sw",
        "tooltip": true
    }
}
